datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String
  phone          String?
  role           String          @default("BUYER") // "BUYER" | "VENDOR"
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  vendorProfile  VendorProfile?
  addresses      Address[]
  paymentMethods PaymentMethod[]
  ordersAsBuyer  Order[]         @relation("BuyerOrders")
  ordersAsVendor Order[]         @relation("VendorOrders")
  fleets         Fleet[]         @relation("VendorFleets")
  sentMessages   Message[]       @relation("SentMessages")
  recvMessages   Message[]       @relation("ReceivedMessages")
}

model VendorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating             Float    @default(0.0)
  verificationStatus String   @default("PENDING") // "PENDING" | "VERIFIED"
  profileCompletion  Int      @default(0)
  specialty          String?
  mainLocation       String?
  pricePerLiter      Float    @default(0)
  defaultCapacity    Int      @default(0)
}

model Address {
  id            String  @id @default(uuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName String
  province      String
  city          String
  district      String
  postalCode    String
  street        String
  details       String?
  isPrimary     Boolean @default(false)
}

model PaymentMethod {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String 
  details String 
}

model Order {
  id               String   @id @default(uuid())
  orderNumber      String   @unique 
  buyerId          String
  vendorId         String
  volume           Int      
  pricePerLiter    Float
  serviceFee       Float    @default(0)
  totalPrice       Float
  paymentMethod    String?
  paymentStatus    String   @default("PENDING") // "PENDING" | "LUNAS" | "GAGAL"
  deliveryNotes    String?
  waterType        String?
  deliverySchedule String?
  status           String   @default("MENUNGGU_KONFIRMASI") // MENUNGGU_KONFIRMASI | DIKONFIRMASI | DISIAPKAN | DALAM_PERJALANAN | SELESAI | DITOLAK
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  buyer            User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  vendor           User     @relation("VendorOrders", fields: [vendorId], references: [id])
  assignedFleet    Fleet?   @relation(fields: [fleetId], references: [id])
  fleetId          String?
}

model Fleet {
  id           String  @id @default(uuid())
  vendorId     String
  vendor       User    @relation("VendorFleets", fields: [vendorId], references: [id])
  truckId      String  
  driverName   String
  truckType    String? // e.g. Volvo FH16
  licensePlate String?
  capacity     Int?
  status       String  @default("TERSEDIA") // "TERSEDIA" | "SEDANG_BERTUGAS" | "PEMELIHARAAN"
  lat          Float?
  lng          Float?
  orders       Order[]
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}
